# macOS / editor noise
.DS_Store
._*
.AppleDouble
.LSOverride
Icon?
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/

# Local secrets and environment files
.env
.env.*
!.env.example
*.local
*.secret
*.secrets

# Runtime data generated by Docker projects
docker/*/.env
docker/*/data/
docker/*/logs/
docker/*/auth-dir/
docker/*/nginx-config/
docker/*/backup/
docker/*/backups/

# Project-wide generated data
backup/
backups/
logs/
tmp/
temp/
*.log
*.pid

# Generated archives and database/state files
*.tar
*.tar.gz
*.tgz
*.zip
*.bak
*.backup
*.sqlite
*.sqlite3
*.db

# Python / shell tooling caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/

# Node tooling caches, in case docs or helper tools are added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local install/test artifacts
*.tmp
*.temp
*.orig
*.rej
